# Variables for compose.yml files. Not available in the app.

STACK_NAME=app

# Development

DEV_PORT=9080
DEV_ADMINER_PORT=9081

DB_HOST=db
DB_DATABASE=db
DB_USER=db
DB_PASSWORD=db

DOCKER_VOLUMES_FOLDER=./volumes

# Production

PROD_HOST=app.example.com
PROD_SSH="ssh://docker-web"

IMAGE=app
IMAGE_TAG=latest
